#NAVIGATION
alias vm='vim'
alias ls='ls --color=auto'
alias cls='clear'
alias la='ls -A'
alias ..='cd ..'
alias ...='cd ../..'
alias ....='cd ../../..'
alias .....='cd ../../../..'

#MISCELLANEOUS
alias weather='~/scripts/weather.py'
alias forecast='~/scripts/forecast.py'
alias whereami='~/scripts/whereami.py'

#DEV
alias pip='pip3'
